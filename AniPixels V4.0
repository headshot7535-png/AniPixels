local RunService       = game:GetService("RunService")
local TweenService     = game:GetService("TweenService")
local VirtualUser      = game:GetService("VirtualUser")
local Lighting         = game:GetService("Lighting")
-- wait for game + player to be fully ready (queue_on_teleport runs very early)
task.wait(3)
local LP
for _ = 1, 100 do
    LP = Players.LocalPlayer
    if LP and LP:FindFirstChildOfClass("PlayerGui") then break end
    task.wait(0.2)
end
if not LP then return end -- give up if player never loaded
local function getChar()  return LP.Character end
local function getHuman() local c=getChar() return c and c:FindFirstChildOfClass("Humanoid") end
local function getRoot()  local c=getChar() return c and c:FindFirstChild("HumanoidRootPart") end

-- ── Re-execute guard (prevent double load) ───────────────────
if _G.AniPixelsRunning then
    pcall(function()
        if LP and LP.PlayerGui then
            local old = LP.PlayerGui:FindFirstChild("AniPixelsGUI")
            if old then old:Destroy() end
        end
    end)
else
    _G.AniPixelsRunning = true
end

