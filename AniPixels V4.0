UserInputService.JumpRequest:Connect(function()
    if states.infJump then local h=getHuman() if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end end
end)

RunService.Stepped:Connect(function()
    if states.noclip then
        local c=getChar(); if c then
            for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if states.godMode then local h=getHuman() if h then h.MaxHealth=math.huge; h.Health=math.huge end end
end)

RunService.Heartbeat:Connect(function()
    if states.fly then
        local root=getRoot(); if not root then return end
        if not flyBV then flyBV=Instance.new("BodyVelocity",root); flyBV.MaxForce=Vector3.new(1e5,1e5,1e5); flyBV.Velocity=Vector3.zero end
        if not flyBG then flyBG=Instance.new("BodyGyro",root); flyBG.MaxTorque=Vector3.new(1e5,1e5,1e5); flyBG.D=100 end
        local cam=workspace.CurrentCamera; local spd=60; local mv=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv=mv+cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv=mv-cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv=mv-cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv=mv+cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then mv=mv+Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mv=mv-Vector3.new(0,1,0) end
        if mv.Magnitude>0 then mv=mv.Unit end
        flyBV.Velocity=mv*spd; flyBG.CFrame=cam.CFrame
        local h=getHuman() if h then h:ChangeState(Enum.HumanoidStateType.Physics) end
    else
        if flyBV then flyBV:Destroy() flyBV=nil end
        if flyBG then flyBG:Destroy() flyBG=nil end
    end
end)

RunService.Heartbeat:Connect(function()
    if states.fullBright then
        Lighting.Ambient=Color3.fromRGB(255,255,255); Lighting.OutdoorAmbient=Color3.fromRGB(255,255,255)
        Lighting.Brightness=10; Lighting.FogEnd=1e6; Lighting.FogStart=1e6
    end
end)

task.spawn(function()
    while task.wait(55) do
        if states.antiAfk then
            pcall(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new()) end)
            local r=getRoot(); if r then r.CFrame=r.CFrame*CFrame.new(0,0,0.001) end
        end
    end
end)

local function buildESP(p)
    if p==LP then return end
    local char=p.Character; if not char then return end
    -- only use the actual Humanoid head, not pet/accessory parts named "Head"
    local human=char:FindFirstChildOfClass("Humanoid"); if not human then return end
    local head=char:FindFirstChild("Head"); if not head or not head:IsA("BasePart") then return end
    if espBillboards[p.Name] then pcall(function() espBillboards[p.Name]:Destroy() end) espBillboards[p.Name]=nil end
    local ok,bb=pcall(function()
        local b=Instance.new("BillboardGui",head)
        b.Size=UDim2.new(0,100,0,26); b.StudsOffset=Vector3.new(0,2.8,0); b.AlwaysOnTop=true
        local lbl=Instance.new("TextLabel",b)
        lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
        lbl.Text=p.Name; lbl.TextColor3=C.accent
        lbl.Font=Enum.Font.GothamBold; lbl.TextSize=13; lbl.TextStrokeTransparency=0.3
        return b
    end)
    if ok then espBillboards[p.Name]=bb end
end
RunService.Heartbeat:Connect(function()
    if states.esp then
        for _,p in pairs(Players:GetPlayers()) do
            if p~=LP then
                local head=p.Character and p.Character:FindFirstChild("Head")
                if head and not espBillboards[p.Name] then buildESP(p)
                elseif not head and espBillboards[p.Name] then
                    pcall(function() espBillboards[p.Name]:Destroy() end); espBillboards[p.Name]=nil
                end
            end
        end
    end
end)

LP.CharacterAdded:Connect(function(c)
    task.wait(1)
    local h=c:WaitForChild("Humanoid"); h.WalkSpeed=walkSpeed
    if flyBV then flyBV:Destroy() flyBV=nil end
    if flyBG then flyBG:Destroy() flyBG=nil end
end)

-- ── Boss loops ────────────────────────────────────────────────
local function bossLoop(key,path)
    task.spawn(function()
        while true do
            if states[key] then
                -- skip if already in a battle
                if isInBattle() then
                    SLbl.Text="⏳ In battle, waiting: "..path
                    task.wait(2)
                elseif not isBossPresent(path) then
                    SLbl.Text="⏳ Boss not found: "..path
                    task.wait(1)
                else
                    -- auto switch to Raid team
                    applyPresetTeam("Raid")
                    task.wait(0.2)
                    pcall(function()
                        local t=workspace:WaitForChild("Campaign",3):WaitForChild(path,3)
                        RequestBattle:FireServer(t)
                    end)
                    SLbl.Text="⚔ Fired: "..path
                    task.wait(8)
                    if states[key] and not isInBattle() and isBossPresent(path) and not isBossDead(path) then
                        pcall(function()
                            local t=workspace:WaitForChild("Campaign",3):WaitForChild(path,3)
                            RequestBattle:FireServer(t)
                        end)
                        SLbl.Text="🔁 Re-fired: "..path
                    end
                    task.wait(autoFightDelay)
                end
            else task.wait(0.2) end
        end
    end)
end
bossLoop("autoBoros","Boros")
bossLoop("autoZamasu","Fusion Zamasu (Corrupted)")
bossLoop("autoSukuna","Heian Era Sukuna")
bossLoop("autoAllForOne","All For One")
bossLoop("autoDioHeaven","Dio Over Heaven")
bossLoop("autoMadara","Madara Ten Tails")

-- ── Door Unlock loop ─────────────────────────────────────────
task.spawn(function()
    while true do
        if states.doorUnlock then
            -- collect all missing pets across all selected doors
            local allMissing = {}
            local dInv = LP:FindFirstChild("DoodleInv")
            for doorName,_ in pairs(selectedDoors) do
                local needs = DOOR_CONFIG[doorName] or {}
                for _, n in ipairs(needs) do
                    -- checkOwned checks base name + Giant/Mega/Titan/Sparking tiers
                    local have = checkOwned(n.pet)
                    if not have then
                        -- avoid duplicates
                        local dup=false
                        for _,m in ipairs(allMissing) do if m.pet==n.pet then dup=true; break end end
                        if not dup then table.insert(allMissing, {pet=n.pet, door=doorName}) end
                    end
                end
            end

            if next(selectedDoors)==nil then
                DoorStatusLbl.Text = "  Select doors to unlock"
                task.wait(1); continue
            end

            if #allMissing == 0 then
                DoorStatusLbl.Text = "✨ All doors unlocked!"
                SLbl.Text = "🔓 All doors done!"
                states.doorUnlock = false
                saveSettings()
                task.wait(3)
            else
                local target = allMissing[1]
                DoorStatusLbl.Text = "⚔ "..target.door..": farming "..target.pet
                SLbl.Text = "🔓 Need: "..target.pet

                if isInBattle() then task.wait(2); continue end

                local root = getRoot()
                if not root then task.wait(1); continue end

                -- find model by exact pet name and fire RequestBattle
                local battleModel = findCampaignModelForPet(target.pet)
                if battleModel then
                    if not states.farmNoTP then
                        pcall(function()
                            local pos = battleModel:GetModelCFrame().Position
                            if (root.Position-pos).Magnitude > 30 then
                                root.CFrame = CFrame.new(pos+Vector3.new(0,5,0))
                                task.wait(0.5)
                            end
                        end)
                    end
                    pcall(function() RequestBattle:FireServer(battleModel) end)
                else
                    DoorStatusLbl.Text = "⚠ Can't find model for: "..target.pet
                    task.wait(2)
                end

                task.wait(autoFightDelay + 1)
            end
        else
            task.wait(0.3)
        end
    end
end)

-- ── Dragon Ball loop ─────────────────────────────────────────
local VIM_DB = game:GetService("VirtualInputManager")

local function countBackpackBalls()
    local count = 0
    pcall(function()
        local backpack = LP.PlayerGui:FindFirstChild("ScreenGui")
            and LP.PlayerGui.ScreenGui:FindFirstChild("DragonBallBackpack")
        if backpack then
            for i = 1, 7 do
                local slot = backpack:FindFirstChild(tostring(i))
                if slot and slot.Visible then count = count + 1 end
            end
        end
    end)
    return count
end

task.spawn(function()
    while true do
        if states.dragonBall then
            local root = getRoot()
            if not root then task.wait(1); continue end

            -- check how many balls player already has
            local owned = countBackpackBalls()

            if owned >= 7 then
                -- already have all 7, stop collecting
                DBStatus.Text = "✨ You have all 7! Make a wish!"
                DBFound.Text = "Owned: 7/7"
                SLbl.Text = "All 7 Dragon Balls owned!"
                -- update all dots gold
                for i = 1, 7 do
                    if dbDots[i] then
                        dbDots[i].BackgroundColor3 = Color3.fromRGB(255,210,50)
                        local n = dbDots[i]:FindFirstChildOfClass("TextLabel")
                        if n then n.TextColor3 = Color3.fromRGB(0,0,0) end
                    end
                end
                task.wait(3)
            else
                -- scan workspace for uncollected DragonBall1-7
                local ws = game:GetService("Workspace")
                local found = {}
                for i = 1, 7 do
                    local ball = ws:FindFirstChild("DragonBall"..i)
                    if ball then table.insert(found, {idx=i, model=ball}) end
                end

                -- update dot indicators
                for i = 1, 7 do
                    if dbDots[i] then
                        local inWorld = false
                        for _,f in ipairs(found) do if f.idx==i then inWorld=true break end end
                        dbDots[i].BackgroundColor3 = inWorld
                            and Color3.fromRGB(220,160,0)
                            or  Color3.fromRGB(30,25,5)
                        local numLbl = dbDots[i]:FindFirstChildOfClass("TextLabel")
                        if numLbl then
                            numLbl.TextColor3 = inWorld and Color3.fromRGB(255,255,255) or Color3.fromRGB(100,80,20)
                        end
                    end
                end

                DBFound.Text = "Owned: "..owned.."/7 · World: "..#found

                if #found == 0 then
                    DBStatus.Text = "⏳ Waiting for Dragon Balls to spawn..."
                    SLbl.Text = "Dragon Balls: none spawned"
                    task.wait(3)
                else
                    -- collect each found ball one by one
                    for _, entry in ipairs(found) do
                        if not states.dragonBall then break end

                        -- re-check owned count before each ball
                        owned = countBackpackBalls()
                        if owned >= 7 then break end

                        local ball = entry.model
                        local pos
                        pcall(function()
                            pos = ball:IsA("Model") and ball:GetModelCFrame().Position
                                or ball:IsA("BasePart") and ball.Position
                                or ball:FindFirstChildOfClass("BasePart") and ball:FindFirstChildOfClass("BasePart").Position
                        end)

                        if pos then
                            DBStatus.Text = "🟡 Going to Ball "..entry.idx.." (have "..owned..")"
                            SLbl.Text = "Dragon Ball "..entry.idx.." → TP"
                            DBLog.Text = "  Ball "..entry.idx.." at "..
                                string.format("%.0f, %.0f, %.0f", pos.X, pos.Y, pos.Z)

                            root.CFrame = CFrame.new(pos + Vector3.new(0, 4, 0))
                            task.wait(0.5)

                            VIM_DB:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
                            task.wait(0.15)
                            VIM_DB:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                            task.wait(0.8)

                            DBStatus.Text = "✓ Collected Ball "..entry.idx
                        end
                    end
                    task.wait(2)
                end
            end
        else
            task.wait(0.3)
        end
    end
end)

-- ── Auto Re-Execute on disconnect / new server ──────────────
local REEXEC_URL = "https://raw.githubusercontent.com/headshot7535-png/AniPixels/main/AniPixels%20V4.0"

-- Carry toggle state across servers via _G
if _G.AniPixels_AutoRejoin and not states.autoReExec then
    states.autoReExec = true
    saveSettings()
end

-- Keep _G in sync with toggle
local function syncRejoinFlag()
    _G.AniPixels_AutoRejoin = states.autoReExec
end
syncRejoinFlag()

-- Fire when the SERVER kicks/teleports you out (save _G flag)
pcall(function()
    game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(teleportState)
        if teleportState == Enum.TeleportState.RequestedByServer then
            syncRejoinFlag()
            -- arm re-execute right as server is kicking us
            if queue_on_teleport and states.autoReExec then
                pcall(function()
                    queue_on_teleport('loadstring(game:HttpGet("'..REEXEC_URL..'",true))()')
                end)
            end
        end
    end)
end)

-- queue_on_teleport: queues script to run in next server, avoids CrossExperience block
local function armQueueOnTeleport()
    pcall(function()
        if queue_on_teleport and states.autoReExec then
            queue_on_teleport('loadstring(game:HttpGet("'..REEXEC_URL..'",true))()')
        end
    end)
end
armQueueOnTeleport()

-- Keep _G flag live and keep queue_on_teleport armed while toggle is on
task.spawn(function()
    local wasOn = false
    while true do
        task.wait(2)
        syncRejoinFlag()
        -- re-arm queue_on_teleport whenever toggle flips on
        if states.autoReExec and not wasOn then
            pcall(function()
                armQueueOnTeleport()
            end)
        end
        wasOn = states.autoReExec
    end
end)
-- ── Server Hop loop (Dragon Ball aware) ─────────────────────
task.spawn(function()
    local TeleportService = game:GetService("TeleportService")
    local HttpService     = game:GetService("HttpService")
    local placeId         = game.PlaceId
    local currentJobId    = game.JobId
    local isHopping       = false  -- prevent double hops

    local function countDragonBalls()
        local ws = game:GetService("Workspace")
        local count = 0
        for i = 1, 7 do
            if ws:FindFirstChild("DragonBall"..i) then count = count + 1 end
        end
        return count
    end

    local function hopToNext()
        if isHopping then return end
        isHopping = true

        SLbl.Text = "🌐 Finding next server..."
        local nextServerId = nil
        pcall(function()
            local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
            local res = HttpService:JSONDecode(game:HttpGet(url))
            if res and res.data then
                for _, srv in ipairs(res.data) do
                    if srv.id ~= currentJobId and srv.playing < srv.maxPlayers then
                        nextServerId = srv.id
                        break
                    end
                end
            end
        end)

        -- arm re-execute in new server BEFORE teleporting
        pcall(function()
            if queue_on_teleport and states.autoReExec then
                queue_on_teleport('loadstring(game:HttpGet("'..REEXEC_URL..'",true))()')
            end
        end)

        -- store hop state in _G so new server restores it
        _G.AniPixels_ServerHop = true

        task.wait(0.3)
        if nextServerId then
            SLbl.Text = "🌐 Hopping..."
            pcall(function() TeleportService:TeleportToPlaceInstance(placeId, nextServerId) end)
        else
            SLbl.Text = "🌐 No server found, rejoining..."
            pcall(function() TeleportService:Teleport(placeId) end)
        end

        -- if teleport fails somehow, re-enable after 15s
        task.wait(15)
        isHopping = false
    end

    -- restore serverHop from _G if carried over from previous server
    if _G.AniPixels_ServerHop then
        _G.AniPixels_ServerHop = nil
        task.defer(function()
            if setServerHop then setServerHop(true) end
        end)
    end

    while true do
        if states.serverHop and not isHopping then
            -- wait for server to load dragon balls
            task.wait(10)

            local ballCount = countDragonBalls()
            SLbl.Text = "🌐 Server check: "..ballCount.."/7 Dragon Balls"

            if ballCount > 0 then
                -- balls here! pause hopping, auto-enable collector
                SLbl.Text = "🟡 "..ballCount.." ball(s) found! Collecting..."
                if not states.dragonBall then
                    states.dragonBall = true
                    setDragon(true)
                end
                -- wait until all balls collected/despawned
                repeat
                    task.wait(3)
                    ballCount = countDragonBalls()
                until ballCount == 0 or not states.serverHop

                if states.serverHop then
                    task.wait(2)
                    hopToNext()
                end
            else
                -- no balls, hop to next
                SLbl.Text = "🌐 No balls here, hopping..."
                task.wait(0.5)
                hopToNext()
            end
        else
            task.wait(0.5)
        end
    end
end)
-- ── Fast Forward loop ───────────────────────────────────────
task.spawn(function()
    local FF = game:GetService("ReplicatedStorage"):WaitForChild("State",5):WaitForChild("FastForward",5)
    while true do
        task.wait(0.5)
        if states.fastForward then
            if FF and FF.Value ~= 0.25 then FF.Value = 0.25 end
        else
            if FF and FF.Value ~= 1 then FF.Value = 1 end
        end
    end
end)

