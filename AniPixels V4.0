end
local function updateChainPreview(base)
    if base=="" then
        for i=0,3 do tierRows[i].name.Text="—"; tierRows[i].count.Text="x0" end
        MSChain.Text="Chain: —"; return
    end
    for i=0,3 do
        local name=getTierName(base,i)
        local dInv=LP:FindFirstChild("DoodleInv")
        local cnt=0
        if dInv then local iv=dInv:FindFirstChild(name) if iv then cnt=iv.Value end end
        tierRows[i].name.Text=name
        tierRows[i].count.Text="x"..cnt
    end
    MSChain.Text="Chain: "..base.." → Giant → Mega → Titan"
end

-- Pet row builder
local petBtns={}
local allBasePets={}

local function getPetCount(name)
    local d=LP:FindFirstChild("DoodleInv"); if not d then return 0 end
    local iv=d:FindFirstChild(name); return iv and iv.Value or 0
end

local function refreshPetHighlights()
    local count=0
    for _,_ in pairs(mergeTargets) do count=count+1 end
    for n,pb in pairs(petBtns) do
        local sel=mergeTargets[n]==true
        pb.BackgroundColor3=sel and Color3.fromRGB(0,55,28) or Color3.fromRGB(10,15,22)
        for _,child in pairs(pb:GetChildren()) do
            if child:IsA("TextLabel") and child.Name=="nameLbl" then
                child.TextColor3=sel and C.green or C.text
            end
            if child:IsA("Frame") and child.Name=="checkBox" then
                child.BackgroundColor3=sel and C.green or C.border
                local tick=child:FindFirstChild("tick")
                if tick then tick.Visible=sel end
            end
        end
    end
    local names={}
    for n,_ in pairs(mergeTargets) do names[#names+1]=n end
    local txt=count==0 and "No targets selected" or count.." selected: "..table.concat(names,", ")
    MSStatus.Text=(states.mergeActive and "ON" or "OFF").." · "..txt
    SLbl.Text=count.." merge target(s) selected"
    saveSettings()
end

local function toggleBasePet(base)
    if mergeTargets[base] then
        mergeTargets[base]=nil
    else
        mergeTargets[base]=true
    end
    -- chain preview shows last toggled
    updateChainPreview(base)
    refreshPetHighlights()
end

local function buildPetList(filter)
    -- clear
    for _,c in pairs(PetScroll:GetChildren()) do if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end end
    petBtns={}

    local dInv=LP:FindFirstChild("DoodleInv"); if not dInv then PHLbl.Text="DoodleInv not found"; return end

    -- collect all base names including those only present as Giant/Mega/Titan variants
    local prefixes={"Giant ","Mega ","Titan ","Sparking "}
    local baseSet={}
    for _,iv in pairs(dInv:GetChildren()) do
        if iv:IsA("IntValue") and iv.Value>0 then
            local n=iv.Name
            -- strip any known prefix to find the base name
            local base=n
            for _,p in ipairs(prefixes) do
                if n:sub(1,#p)==p then base=n:sub(#p+1); break end
            end
            -- apply filter on base name
            local lc=base:lower()
            local passFilter=(filter=="" or lc:find(filter:lower(),1,true))
            if passFilter then
                -- accumulate total across all tiers for sorting; base entry created once
                if not baseSet[base] then baseSet[base]=0 end
                baseSet[base]=baseSet[base]+iv.Value
            end
        end
    end

    -- sort by count desc
    local sorted={}
    for n,cnt in pairs(baseSet) do table.insert(sorted,{name=n,count=cnt}) end
    table.sort(sorted,function(a,b) return a.count>b.count end)

    PHLbl.Text="SELECT BASE PET  ·  "..#sorted.." found"

    for i,entry in ipairs(sorted) do
        local base=entry.name
        -- check all tiers
        local t0=getPetCount(base)
        local t1=getPetCount("Giant "..base)
        local t2=getPetCount("Mega "..base)
        local t3=getPetCount("Titan "..base)

        local btn=Instance.new("TextButton",PetScroll)
        btn.Size=UDim2.new(1,-4,0,28); btn.LayoutOrder=i
        btn.BackgroundColor3= (base==mergeTargetBase) and Color3.fromRGB(0,60,30) or Color3.fromRGB(10,15,22)
        btn.TextColor3= (base==mergeTargetBase) and C.green or C.text
        btn.BorderSizePixel=0; btn.Font=Enum.Font.GothamBold; btn.TextSize=0
        Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)

        -- left: name
        local nLbl=Instance.new("TextLabel",btn)
        nLbl.Text=base; nLbl.Size=UDim2.new(0.5,-4,1,0); nLbl.Position=UDim2.new(0,8,0,0)
        nLbl.BackgroundTransparency=1; nLbl.TextColor3= (base==mergeTargetBase) and C.green or C.text
        nLbl.Font=Enum.Font.GothamBold; nLbl.TextSize=10; nLbl.TextXAlignment=Enum.TextXAlignment.Left

        -- right: tier counts
        local tierStr=string.format("①x%d  ②x%d  ③x%d  ④x%d",t0,t1,t2,t3)
        local cLbl=Instance.new("TextLabel",btn)
        cLbl.Text=tierStr; cLbl.Size=UDim2.new(0.5,-8,1,0); cLbl.Position=UDim2.new(0.5,0,0,0)
        cLbl.BackgroundTransparency=1; cLbl.TextColor3=C.sub
        cLbl.Font=Enum.Font.Code; cLbl.TextSize=8; cLbl.TextXAlignment=Enum.TextXAlignment.Right

        -- checkbox
        local checkBox=Instance.new("Frame",btn)
        checkBox.Name="checkBox"
        checkBox.Size=UDim2.new(0,14,0,14); checkBox.Position=UDim2.new(1,-18,0.5,-7)
        checkBox.BackgroundColor3=mergeTargets[base] and C.green or C.border; checkBox.BorderSizePixel=0
        Instance.new("UICorner",checkBox).CornerRadius=UDim.new(0,3)
        local tick=Instance.new("TextLabel",checkBox)
        tick.Name="tick"; tick.Text="✓"; tick.Size=UDim2.new(1,0,1,0)
        tick.BackgroundTransparency=1; tick.TextColor3=Color3.fromRGB(255,255,255)
        tick.Font=Enum.Font.GothamBold; tick.TextSize=9; tick.Visible=mergeTargets[base]==true

        nLbl.Name="nameLbl"
        petBtns[base]=btn
        local bname=base
        btn.MouseButton1Click:Connect(function() toggleBasePet(bname) end)
    end

    refreshPetHighlights()
    -- show chain for first selected or first in list
    local firstSel=""
    for n,_ in pairs(mergeTargets) do firstSel=n break end
    updateChainPreview(firstSel)
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function() buildPetList(SearchBox.Text) end)
RefreshBtn2.MouseButton1Click:Connect(function() buildPetList(SearchBox.Text) end)
task.delay(1.2, function() buildPetList("") end)

-- ============================================================
--  MERGE LOOP LOGIC
-- ============================================================
local function pressE()
    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

-- Returns: petName, tierIndex — scans ALL selected targets, returns first ready tier
local function getActiveMergeTier()
    local dInv=LP:FindFirstChild("DoodleInv"); if not dInv then return nil,nil end
    for base,_ in pairs(mergeTargets) do
        for tier=0,2 do  -- T3 (Titan) is end-game, skip
            local name=getTierName(base,tier)
            local iv=dInv:FindFirstChild(name)
            local cnt=iv and iv.Value or 0
            if cnt>=mergeThreshold then return name,tier,base end
        end
    end
    return nil,nil,nil
end

task.spawn(function()
    while true do
        local anyTarget=next(mergeTargets)~=nil
        if states.mergeActive and anyTarget then
            local petName,tier,activeBase=getActiveMergeTier()
            if petName then
                local dInv=LP:FindFirstChild("DoodleInv")
                local cnt=dInv and dInv:FindFirstChild(petName) and dInv:FindFirstChild(petName).Value or 0

                MSStatus.Text="🔀 Merging T"..tier.." "..petName.." (x"..cnt..")"
                SLbl.Text="Merging: "..petName.." x"..cnt

                -- Equip 4x of this pet (fire twice to ensure server receives it)
                local squad={["1"]=petName,["2"]=petName,["3"]=petName,["4"]=petName}
                pcall(function() SquadUpdate:FireServer(squad) end)
                task.wait(0.1)
                pcall(function() SquadUpdate:FireServer(squad) end)
                task.wait(0.1)

                -- TP to merge circle only if not already close
                local root=getRoot()
                if root then
                    pcall(function()
                        local model=workspace:WaitForChild("Map",3):WaitForChild("Lab",3):WaitForChild("Magic Circle",3)
                        local pos=model:GetModelCFrame().Position
                        local dist=(root.Position-pos).Magnitude
                        if dist>20 then
                            root.CFrame=CFrame.new(pos+Vector3.new(0,5,0))
                            task.wait(0.2)
                        end
                    end)
                end

                -- Press E rapidly 3 times to ensure merge registers
                pressE()
                task.wait(0.1)
                pressE()
                task.wait(0.1)
                pressE()
                task.wait(0.3)

                -- refresh list
                buildPetList(SearchBox.Text)
            else
                -- no tier ready yet
                local names={}
                for n,_ in pairs(mergeTargets) do names[#names+1]=n end
                MSStatus.Text="⏳ Waiting · "..table.concat(names,", ").." (need x"..mergeThreshold..")"
                task.wait(2)
            end
        else
            task.wait(0.5)
        end
    end
end)


