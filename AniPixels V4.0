        TweenService:Create(FThumb,fti,{Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=C.sub}):Play()
        fsc.Color=C.border; FSTitle.TextColor3=C.text
        FSStatus.Text="OFF · No targets"
    end
end
