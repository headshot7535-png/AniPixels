        if anyOn then
            TweenService:Create(SDot,TweenInfo.new(0.5),{BackgroundColor3=C.green}):Play()
            task.wait(0.5)
            TweenService:Create(SDot,TweenInfo.new(0.5),{BackgroundColor3=C.accent}):Play()
        end
    end
end)

