-- ============================================================
--  TAB SYSTEM
-- ============================================================
local tabs = {}         -- name -> {btn, page}
local activeTab = nil

local tabDefs = {
    {"⚙️","Features"},
    {"⚔️","Bosses"},
    {"🔀","Merge"},
}

local function switchTab(name)
    activeTab = name
    for tname, td in pairs(tabs) do
        local on = (tname==name)
        if on then
            td.btn.BackgroundColor3=C.accent
            td.btn.TextColor3=Color3.fromRGB(255,255,255)
        else
            td.btn.BackgroundColor3=Color3.fromRGB(0,0,0,0)
            td.btn.TextColor3=C.sub
            td.btn.BackgroundTransparency=1
        end
        td.page.Visible=on
    end
end

local function makeTabBtn(icon, name)
    local btn=Instance.new("TextButton",TabBar)
    btn.Text=icon.." "..name; btn.Size=UDim2.new(0,62,0,26)
    btn.BackgroundTransparency=1; btn.TextColor3=C.sub
    btn.Font=Enum.Font.GothamBold; btn.TextSize=10; btn.BorderSizePixel=0
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,7)
    local page=Instance.new("ScrollingFrame",ContentOuter)
    page.Size=UDim2.new(1,0,1,0); page.BackgroundTransparency=1
    page.BorderSizePixel=0; page.ScrollBarThickness=3
    page.ScrollBarImageColor3=C.accent; page.Visible=false
    page.AutomaticCanvasSize=Enum.AutomaticSize.Y; page.CanvasSize=UDim2.new(0,0,0,0)
    local layout=Instance.new("UIListLayout",page)
    layout.Padding=UDim.new(0,6); layout.SortOrder=Enum.SortOrder.LayoutOrder
    layout.HorizontalAlignment=Enum.HorizontalAlignment.Center
    Instance.new("UIPadding",page).PaddingTop=UDim.new(0,8)
    tabs[name]={btn=btn, page=page, layout=layout}
    btn.MouseButton1Click:Connect(function() switchTab(name) end)
    return page
end

