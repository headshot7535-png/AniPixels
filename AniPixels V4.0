local states = {
    infJump=false, noclip=false, godMode=false, fly=false,
    antiAfk=false, fullBright=false, esp=false,
    autoBoros=false, autoZamasu=false, autoSukuna=false,
    autoAllForOne=false, autoDioHeaven=false, autoMadara=false,
    mergeActive=false,
    farmNoTP=false, farmActive=false,
    serverHop=false,
    dragonBall=false,
    doorUnlock=false,
    fastForward=false,
    autoReExec=false,
}
local walkSpeed   = 16
local hopDelay    = 10  -- seconds to wait before hopping
local flyBV, flyBG
local espBillboards = {}
local autoFightDelay = 1.5
-- merge
local mergeThreshold  = 20   -- merge when count hits this
local mergeTargetBase = ""   -- legacy single (unused)
local mergeTargets    = {}   -- multi-select: set of base names
-- farm
local farmTargets   = {}   -- set of campaign model names to farm
local farmIndex     = 1    -- round-robin index for farm targets
local petToCampaign = {}   -- pet name -> campaign folder name
local petNameList   = {}   -- sorted list of all pet names

-- build a pet->campaign map from workspace
local function refreshPetCampaignMap()
    petToCampaign = {}
    petNameList = {}
    pcall(function()
        local campaign = workspace:FindFirstChild("Campaign")
        if not campaign then return end
        local seen = {}
        for _, model in pairs(campaign:GetChildren()) do
            local pets = model:FindFirstChild("Pets")
            if pets then
                for _, pet in pairs(pets:GetChildren()) do
                    -- use exact pet name as it appears in game
                    if not seen[pet.Name] then
                        seen[pet.Name] = true
                        -- prefer non-Safari source for campaign label
                        if not petToCampaign[pet.Name] or petToCampaign[pet.Name]=="Safari" then
                            petToCampaign[pet.Name] = model.Name
                        end
                        table.insert(petNameList, pet.Name)
                    end
                end
            end
        end
        table.sort(petNameList)
    end)
end

local selectedDoors = {}   -- set of door names to unlock
local farmTeam      = {}   -- current active squad {["1"]=name,...}
local savedTeams    = {}   -- name -> {["1"]=name,...}
local farmTeamName  = ""   -- active saved team name

-- upgrade chain: base -> Giant X -> Mega X -> Titan X
local function getTierName(base, tier)
    if tier == 0 then return base end
    if tier == 1 then return "Giant "..base end
    if tier == 2 then return "Mega "..base end
    if tier == 3 then return "Titan "..base end
    return base
end

-- ============================================================
--  SETTINGS
-- ============================================================
local SETTINGS_FILE = "anipixels_settings.json"

local function encodeSettings()
    local t = {}
    for k,v in pairs(states) do t[#t+1]='"'..k..'":'..(v and"true"or"false") end
    t[#t+1]='"walkSpeed":'..walkSpeed
    t[#t+1]='"autoFightDelay":'..autoFightDelay
    t[#t+1]='"hopDelay":'..hopDelay
    t[#t+1]='"mergeThreshold":'..mergeThreshold
    t[#t+1]='"mergeTargetBase":"'..mergeTargetBase..'"'
    -- farm targets
    local ftnames={}
    for n,_ in pairs(farmTargets) do ftnames[#ftnames+1]=n end
    t[#t+1]='"farmTargets":"'..table.concat(ftnames,",")..'"'
    local sdnames={}
    for n,_ in pairs(selectedDoors) do sdnames[#sdnames+1]=n end
    t[#t+1]='"selectedDoors":"'..table.concat(sdnames,"|")..'"'  
    -- saved teams: flat keys "Raid_1".."PVP_4"
    local presetKeys={"Raid","Farm","Trials","PVP"}
    for _,pk in ipairs(presetKeys) do
        local slots=savedTeams[pk] or {["1"]="",["2"]="",["3"]="",["4"]=""}
        for si=1,4 do
            local v=(slots[tostring(si)] or ""):gsub('"',"'")
            t[#t+1]='"'..pk..'_'..si..'":"'..v..'"'
        end
    end
    t[#t+1]='"farmTeamName":"'..farmTeamName..'"' 
    t[#t+1]='"farmNoTP":'.. (states.farmNoTP and "true" or "false")
    local tnames={}
    for n,_ in pairs(mergeTargets) do tnames[#tnames+1]=n end
    t[#t+1]='"mergeTargets":"'..table.concat(tnames,",")..'"'
    return "{"..table.concat(t,",").."}"
end
local function saveSettings()
    pcall(function() writefile(SETTINGS_FILE, encodeSettings()) end)
end
local function parseJSON(s)
    local t={}
    for k,v in s:gmatch('"([^"]+)":%s*([%w%.%-]+)') do
        if v=="true" then t[k]=true elseif v=="false" then t[k]=false else t[k]=tonumber(v) end
    end
    for k,v in s:gmatch('"([^"]+)":%s*"([^"]*)"') do t[k]=v end
    return t
end
local LS={}
pcall(function()
    if isfile(SETTINGS_FILE) then
        local raw=readfile(SETTINGS_FILE)
        -- migrate old ;;/@@@/savedTeams formats: strip them so we use new flat keys
        raw=raw:gsub('"savedTeams":"[^"]*"','')
        LS=parseJSON(raw)
    end
end)
for k,v in pairs(LS) do if states[k]~=nil then states[k]=v end end
if LS.walkSpeed      then walkSpeed=LS.walkSpeed end
if LS.autoFightDelay then autoFightDelay=LS.autoFightDelay end
if LS.hopDelay then hopDelay=LS.hopDelay end
if LS.mergeThreshold then mergeThreshold=LS.mergeThreshold end
if LS.mergeTargetBase then mergeTargetBase=LS.mergeTargetBase end
if LS.mergeTargets then
    for name in (LS.mergeTargets..","):gmatch("([^,]+),") do
        mergeTargets[name]=true
    end
end
if LS.farmTargets then
    for name in (LS.farmTargets..","):gmatch("([^,]+),") do
        farmTargets[name]=true
    end
end
if LS.selectedDoors then
    for name in (LS.selectedDoors.."|"):gmatch("([^|]+)|") do
        selectedDoors[name]=true
    end
end
-- load preset teams from flat keys
do
    local presetKeys={"Raid","Farm","Trials","PVP"}
    for _,pk in ipairs(presetKeys) do
        local s1=LS[pk.."_1"] or ""; local s2=LS[pk.."_2"] or ""
        local s3=LS[pk.."_3"] or ""; local s4=LS[pk.."_4"] or ""
        if s1~="" or s2~="" or s3~="" or s4~="" then
            savedTeams[pk]={["1"]=s1,["2"]=s2,["3"]=s3,["4"]=s4}
        end
    end
end
if LS.farmTeamName then farmTeamName=LS.farmTeamName end
-- restore farmTeam from saved Farm preset if exists
if savedTeams["Farm"] then farmTeam=savedTeams["Farm"] end

