local RequestBattle2 = RequestBattle

local function isInBattle()
    pcall(function()
        local gui=LP.PlayerGui:FindFirstChild("ScreenGui")
        if gui then
            local bf=gui:FindFirstChild("BattleFrame")
            if bf then return bf.Visible end
        end
    end)
    -- fallback: check all ScreenGuis
    for _,sg in pairs(LP.PlayerGui:GetChildren()) do
        if sg:IsA("ScreenGui") then
            local bf=sg:FindFirstChild("BattleFrame")
            if bf and bf.Visible then return true end
        end
    end
    return false
end

