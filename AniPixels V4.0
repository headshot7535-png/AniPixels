local RequestBattle = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("RequestBattle")

-- Click the Battle button in BattleChat UI (more reliable than remotes for Safari)
local VIM = game:GetService("VirtualInputManager")
local function clickBattleButton()
    local ok = false
    pcall(function()
        local sc = LP.PlayerGui:FindFirstChild("ScreenGui")
        if not sc then return end
        local btn = sc:FindFirstChild("BattleChats") and
                    sc.BattleChats:FindFirstChild("BattleChat") and
                    sc.BattleChats.BattleChat:FindFirstChild("Battle")
        if btn and btn.Visible then
            -- fire click event directly, no position needed
            btn:FireClick()
            ok = true
        end
    end)
    return ok
end

-- Walk up to a campaign model and wait for BattleChat to appear
-- Find the campaign model for a pet by exact name match only
local function findCampaignModelForPet(petName)
    local result = nil
    pcall(function()
        local campaign = workspace:WaitForChild("Campaign", 5)
        for _, model in pairs(campaign:GetChildren()) do
            local pets = model:FindFirstChild("Pets")
            if pets and pets:FindFirstChild(petName) then
                result = model
                return
            end
        end
    end)
    return result
end

local function walkToCampaignAndBattle(folderName, petName)
    local model = findCampaignModelForPet(petName or folderName)
    if not model then return false end
    -- TP to model if needed
    if not states.farmNoTP then
        pcall(function()
            local root = getRoot()
            if not root then return end
            local pos = model:GetModelCFrame().Position
            if (root.Position - pos).Magnitude > 30 then
                root.CFrame = CFrame.new(pos + Vector3.new(0,5,0))
                task.wait(0.5)
            end
        end)
    end
    -- fire RequestBattle with the campaign model (parent of Pets folder)
    local ok = false
    pcall(function()
        RequestBattle:FireServer(model)
        ok = true
    end)
    return ok
end

