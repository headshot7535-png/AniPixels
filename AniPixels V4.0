local doorBtns = {}

local function checkOwned(petName)
    local owned = false
    pcall(function()
        local dInv = LP:FindFirstChild("DoodleInv")
        if dInv then
            -- check base name and all tiers (Giant/Mega/Titan)
            local variants = {petName, "Giant "..petName, "Mega "..petName, "Titan "..petName, "Sparking "..petName}
            for _,iv in pairs(dInv:GetChildren()) do
                for _,v in ipairs(variants) do
                    if iv.Name==v and iv.Value>0 then owned=true; break end
                end
                if owned then break end
            end
        end
    end)
    return owned
end

local function buildDoorList(filter)
    for _,c in pairs(DoorScroll:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
    end
    doorBtns = {}

    for i, dname in ipairs(doorNames) do
        if filter=="" or dname:lower():find(filter:lower(),1,true) then
            local needs = DOOR_CONFIG[dname] or {}
            local owned = 0
            for _,n in ipairs(needs) do if checkOwned(n.pet) then owned=owned+1 end end
            local allDone = owned==#needs

            local Row=Instance.new("TextButton",DoorScroll)
            Row.Size=UDim2.new(1,-6,0,44); Row.BackgroundColor3=C.card
            Row.BorderSizePixel=0; Row.Text=""; Row.LayoutOrder=i
            Instance.new("UICorner",Row).CornerRadius=UDim.new(0,8)
            local rStroke=Instance.new("UIStroke",Row); rStroke.Color=C.border; rStroke.Thickness=1

            -- door name
            local dLbl=Instance.new("TextLabel",Row)
            dLbl.Text=(selectedDoors[dname] and "✓ " or "")..dname
            dLbl.Size=UDim2.new(1,-80,0,20); dLbl.Position=UDim2.new(0,10,0,4)
            dLbl.BackgroundTransparency=1; dLbl.TextColor3=allDone and C.green or C.text
            dLbl.Font=Enum.Font.GothamBold; dLbl.TextSize=10
            dLbl.TextXAlignment=Enum.TextXAlignment.Left

            -- progress
            local pLbl=Instance.new("TextLabel",Row)
            pLbl.Text=owned.."/"..#needs.." pets"
            pLbl.Size=UDim2.new(1,-80,0,14); pLbl.Position=UDim2.new(0,10,0,24)
            pLbl.BackgroundTransparency=1; pLbl.TextColor3=C.sub
            pLbl.Font=Enum.Font.Code; pLbl.TextSize=9
            pLbl.TextXAlignment=Enum.TextXAlignment.Left

            -- check indicator
            local chk=Instance.new("TextLabel",Row)
            chk.Text=selectedDoors[dname] and "✓" or ""
            chk.Size=UDim2.new(0,30,1,0); chk.Position=UDim2.new(1,-36,0,0)
            chk.BackgroundTransparency=1
            chk.TextColor3=C.accent; chk.Font=Enum.Font.GothamBold; chk.TextSize=16

            Row.MouseButton1Click:Connect(function()
                if selectedDoors[dname] then
                    selectedDoors[dname]=nil
                    chk.Text=""; dLbl.Text=dname
                    rStroke.Color=C.border; Row.BackgroundColor3=C.card
                else
                    selectedDoors[dname]=true
                    chk.Text="✓"; dLbl.Text="✓ "..dname
                    rStroke.Color=C.accent; Row.BackgroundColor3=Color3.fromRGB(0,20,40)
                end
                local count=0; for _ in pairs(selectedDoors) do count=count+1 end
                DoorStatusLbl.Text="  "..count.." door(s) selected"
            end)

            -- restore highlight if selected
            if selectedDoors[dname] then
                rStroke.Color=C.accent; Row.BackgroundColor3=Color3.fromRGB(0,20,40)
            end

            doorBtns[dname]=Row
        end
    end

    DoorLayout:ApplyLayout()
    DoorScroll.CanvasSize=UDim2.new(0,0,0,DoorLayout.AbsoluteContentSize.Y+8)
end

buildDoorList("")
DoorSearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    buildDoorList(DoorSearchBox.Text)
end)

-- update req display function (used by loop)
local function updateDoorReqDisplay(doorName)
    local needs = DOOR_CONFIG[doorName] or {}
    local parts = {}
    for _,n in ipairs(needs) do
        local have = checkOwned(n.pet)
        local label = n.pet
        -- show which tier they actually own
        if not have then
            label = "✗ "..n.pet
        else
            -- find which tier they have for display
            local tiers = {"Titan ","Mega ","Giant ","Sparking ",""}
            local dInv = LP:FindFirstChild("DoodleInv")
            if dInv then
                for _,prefix in ipairs(tiers) do
                    local iv = dInv:FindFirstChild(prefix..n.pet)
                    if iv and iv.Value > 0 then
                        label = "✓ "..(prefix..n.pet)
                        break
                    end
                end
            end
        end
        if n.safariOnly and not have then label = "⚠ "..n.pet.." (Safari)" end
        parts[#parts+1] = label
    end
    DoorStatusLbl.Text = "  "..table.concat(parts, " · ")
end

