-- ============================================================
--  REUSABLE COMPONENTS
-- ============================================================
local function SectionLabel(parent, txt, order)
    local f=Instance.new("Frame",parent)
    f.Size=UDim2.new(1,-10,0,16); f.BackgroundTransparency=1; f.LayoutOrder=order
    local line=Instance.new("Frame",f)
    line.Size=UDim2.new(1,0,0,1); line.Position=UDim2.new(0,0,0.5,0)
    line.BackgroundColor3=C.border; line.BorderSizePixel=0
    local bg=Instance.new("Frame",f)
    bg.Size=UDim2.new(0,0,1,0); bg.AutomaticSize=Enum.AutomaticSize.X
    bg.Position=UDim2.new(0,8,0,0); bg.BackgroundColor3=C.bg; bg.BorderSizePixel=0
    Instance.new("UIPadding",bg).PaddingLeft=UDim.new(0,6)
    local lbl=Instance.new("TextLabel",bg)
    lbl.Text=txt:upper(); lbl.Size=UDim2.new(0,0,1,0); lbl.AutomaticSize=Enum.AutomaticSize.X
    lbl.BackgroundTransparency=1; lbl.TextColor3=C.sub
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=9
end

-- Pill toggle card
local function MakeToggleCard(parent, icon, label, desc, order, key, onCb, offCb)
    local Card=Instance.new("Frame",parent)
    Card.Size=UDim2.new(1,-10,0,52); Card.BackgroundColor3=C.card
    Card.BorderSizePixel=0; Card.LayoutOrder=order
    Instance.new("UICorner",Card).CornerRadius=UDim.new(0,10)
    local cs=Instance.new("UIStroke",Card); cs.Color=C.border; cs.Thickness=1

    local iL=Instance.new("TextLabel",Card)
    iL.Text=icon; iL.Size=UDim2.new(0,38,1,0); iL.Position=UDim2.new(0,6,0,0)
    iL.BackgroundTransparency=1; iL.TextSize=20; iL.Font=Enum.Font.GothamBold
    iL.TextXAlignment=Enum.TextXAlignment.Center

    local nL=Instance.new("TextLabel",Card)
    nL.Text=label; nL.Size=UDim2.new(1,-130,0,18); nL.Position=UDim2.new(0,48,0,8)
    nL.BackgroundTransparency=1; nL.TextColor3=C.text
    nL.Font=Enum.Font.GothamBold; nL.TextSize=12; nL.TextXAlignment=Enum.TextXAlignment.Left

    local dL=Instance.new("TextLabel",Card)
    dL.Text=desc; dL.Size=UDim2.new(1,-130,0,14); dL.Position=UDim2.new(0,48,0,28)
    dL.BackgroundTransparency=1; dL.TextColor3=C.sub
    dL.Font=Enum.Font.Gotham; dL.TextSize=9; dL.TextXAlignment=Enum.TextXAlignment.Left

    local badge=Instance.new("TextLabel",Card)
    badge.Text="OFF"; badge.Size=UDim2.new(0,34,0,17); badge.Position=UDim2.new(1,-88,0.5,-8)
    badge.BackgroundColor3=C.panel; badge.TextColor3=C.sub
    badge.Font=Enum.Font.GothamBold; badge.TextSize=9; badge.BorderSizePixel=0
    Instance.new("UICorner",badge).CornerRadius=UDim.new(0,5)

    local Pill=Instance.new("Frame",Card)
    Pill.Size=UDim2.new(0,44,0,24); Pill.Position=UDim2.new(1,-50,0.5,-12)
    Pill.BackgroundColor3=C.border; Pill.BorderSizePixel=0
    Instance.new("UICorner",Pill).CornerRadius=UDim.new(1,0)

    local Thumb=Instance.new("Frame",Pill)
    Thumb.Size=UDim2.new(0,18,0,18); Thumb.Position=UDim2.new(0,3,0.5,-9)
    Thumb.BackgroundColor3=C.sub; Thumb.BorderSizePixel=0
    Instance.new("UICorner",Thumb).CornerRadius=UDim.new(1,0)

    local ti=TweenInfo.new(0.18,Enum.EasingStyle.Quad)
    local function setState(on)
        states[key]=on; saveSettings()
        if on then
            TweenService:Create(Pill, ti,{BackgroundColor3=C.accentD}):Play()
            TweenService:Create(Thumb,ti,{Position=UDim2.new(0,23,0.5,-9),BackgroundColor3=C.accent}):Play()
            cs.Color=C.accentD; badge.Text="ON"; badge.TextColor3=C.accent; badge.BackgroundColor3=Color3.fromRGB(0,30,55)
            if onCb then onCb() end
        else
            TweenService:Create(Pill, ti,{BackgroundColor3=C.border}):Play()
            TweenService:Create(Thumb,ti,{Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=C.sub}):Play()
            cs.Color=C.border; badge.Text="OFF"; badge.TextColor3=C.sub; badge.BackgroundColor3=C.panel
            if offCb then offCb() end
        end
    end

    local Btn=Instance.new("TextButton",Card)
    Btn.Size=UDim2.new(1,0,1,0); Btn.BackgroundTransparency=1; Btn.Text=""; Btn.ZIndex=3
    Btn.MouseButton1Click:Connect(function() setState(not states[key]) end)

    if states[key] then
        Pill.BackgroundColor3=C.accentD; Thumb.Position=UDim2.new(0,23,0.5,-9)
        Thumb.BackgroundColor3=C.accent; cs.Color=C.accentD
        badge.Text="ON"; badge.TextColor3=C.accent; badge.BackgroundColor3=Color3.fromRGB(0,30,55)
    end
    return setState
end

local function MakeSliderCard(parent, label, sub, order, minV, maxV, initV, fmt, onChange)
    local Card=Instance.new("Frame",parent)
    Card.Size=UDim2.new(1,-10,0,58); Card.BackgroundColor3=C.card
    Card.BorderSizePixel=0; Card.LayoutOrder=order
    Instance.new("UICorner",Card).CornerRadius=UDim.new(0,10)
    Instance.new("UIStroke",Card).Color=C.border

    local nL=Instance.new("TextLabel",Card)
    nL.Text=label; nL.Size=UDim2.new(1,-80,0,18); nL.Position=UDim2.new(0,14,0,6)
    nL.BackgroundTransparency=1; nL.TextColor3=C.text
    nL.Font=Enum.Font.GothamBold; nL.TextSize=12; nL.TextXAlignment=Enum.TextXAlignment.Left

    local vL=Instance.new("TextLabel",Card)
    vL.Text=fmt(initV); vL.Size=UDim2.new(0,60,0,18); vL.Position=UDim2.new(1,-68,0,6)
    vL.BackgroundTransparency=1; vL.TextColor3=C.accent
    vL.Font=Enum.Font.Code; vL.TextSize=13; vL.TextXAlignment=Enum.TextXAlignment.Right

    local sL=Instance.new("TextLabel",Card)
    sL.Text=sub; sL.Size=UDim2.new(1,-80,0,12); sL.Position=UDim2.new(0,14,0,24)
    sL.BackgroundTransparency=1; sL.TextColor3=C.sub
    sL.Font=Enum.Font.Gotham; sL.TextSize=9; sL.TextXAlignment=Enum.TextXAlignment.Left

    local Track=Instance.new("Frame",Card)
    Track.Size=UDim2.new(1,-28,0,6); Track.Position=UDim2.new(0,14,0,42)
    Track.BackgroundColor3=C.panel; Track.BorderSizePixel=0
    Instance.new("UICorner",Track).CornerRadius=UDim.new(1,0)

    local initPct=(initV-minV)/(maxV-minV)
    local Fill=Instance.new("Frame",Track)
    Fill.Size=UDim2.new(initPct,0,1,0); Fill.BackgroundColor3=C.accent; Fill.BorderSizePixel=0
    Instance.new("UICorner",Fill).CornerRadius=UDim.new(1,0)

    local Knob=Instance.new("TextButton",Track)
    Knob.Text=""; Knob.Size=UDim2.new(0,16,0,16); Knob.AnchorPoint=Vector2.new(0.5,0.5)
    Knob.Position=UDim2.new(initPct,0,0.5,0)
    Knob.BackgroundColor3=Color3.fromRGB(255,255,255); Knob.BorderSizePixel=0; Knob.ZIndex=4
    Instance.new("UICorner",Knob).CornerRadius=UDim.new(1,0)

    local dragging=false
    local function apply(ix)
        local rel=math.clamp(ix-Track.AbsolutePosition.X,0,Track.AbsoluteSize.X)
        local pct=rel/Track.AbsoluteSize.X
        local v=minV+math.round((maxV-minV)*pct*10)/10
        Fill.Size=UDim2.new(pct,0,1,0); Knob.Position=UDim2.new(pct,0,0.5,0)
        vL.Text=fmt(v); if onChange then onChange(v) end
    end
    Knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then apply(i.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
    Track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then apply(i.Position.X) end end)
    return vL
end

local function MakeActionBtn(parent, icon, label, sub, order, accentCol, cb)
    local Card=Instance.new("TextButton",parent)
    Card.Size=UDim2.new(1,-10,0,44); Card.BackgroundColor3=C.card
    Card.BorderSizePixel=0; Card.LayoutOrder=order; Card.Text=""
    Instance.new("UICorner",Card).CornerRadius=UDim.new(0,10)
    local cs=Instance.new("UIStroke",Card); cs.Color=accentCol or C.border; cs.Thickness=1

    local iL=Instance.new("TextLabel",Card)
    iL.Text=icon; iL.Size=UDim2.new(0,36,1,0); iL.Position=UDim2.new(0,6,0,0)
    iL.BackgroundTransparency=1; iL.TextSize=18; iL.Font=Enum.Font.GothamBold
    iL.TextXAlignment=Enum.TextXAlignment.Center

    local nL=Instance.new("TextLabel",Card)
    nL.Text=label; nL.Size=UDim2.new(1,-50,0,18); nL.Position=UDim2.new(0,46,0,6)
    nL.BackgroundTransparency=1; nL.TextColor3=accentCol or C.text
    nL.Font=Enum.Font.GothamBold; nL.TextSize=11; nL.TextXAlignment=Enum.TextXAlignment.Left

    local dL=Instance.new("TextLabel",Card)
    dL.Text=sub; dL.Size=UDim2.new(1,-50,0,13); dL.Position=UDim2.new(0,46,0,24)
    dL.BackgroundTransparency=1; dL.TextColor3=C.sub
    dL.Font=Enum.Font.Gotham; dL.TextSize=9; dL.TextXAlignment=Enum.TextXAlignment.Left

    Card.MouseButton1Click:Connect(function()
        TweenService:Create(Card,TweenInfo.new(0.08),{BackgroundColor3=Color3.fromRGB(20,25,40)}):Play()
        task.delay(0.15,function() TweenService:Create(Card,TweenInfo.new(0.15),{BackgroundColor3=C.card}):Play() end)
        if cb then cb(Card,nL) end
    end)
    return Card
end

