local function buildFarmPetList(filter)
    for _,c in pairs(FScroll:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end
    end

    local count = 0
    for i, pname in ipairs(petNameList) do
        if filter=="" or pname:lower():find(filter:lower(),1,true) then
            count = count + 1
            local camp = petToCampaign[pname] or "?"

            local Row=Instance.new("TextButton",FScroll)
            Row.Size=UDim2.new(1,-6,0,40); Row.BackgroundColor3=C.card
            Row.BorderSizePixel=0; Row.Text=""; Row.LayoutOrder=i
            Instance.new("UICorner",Row).CornerRadius=UDim.new(0,8)
            local rStroke=Instance.new("UIStroke",Row)
            rStroke.Color=farmTargets[pname] and C.orange or C.border; rStroke.Thickness=1
            if farmTargets[pname] then Row.BackgroundColor3=Color3.fromRGB(35,20,0) end

            local pLbl=Instance.new("TextLabel",Row)
            pLbl.Text=pname; pLbl.Size=UDim2.new(1,-50,0,18); pLbl.Position=UDim2.new(0,10,0,4)
            pLbl.BackgroundTransparency=1; pLbl.TextColor3=farmTargets[pname] and C.orange or C.text
            pLbl.Font=Enum.Font.GothamBold; pLbl.TextSize=11
            pLbl.TextXAlignment=Enum.TextXAlignment.Left

            local cLbl=Instance.new("TextLabel",Row)
            cLbl.Text=camp; cLbl.Size=UDim2.new(1,-50,0,13); cLbl.Position=UDim2.new(0,10,0,23)
            cLbl.BackgroundTransparency=1; cLbl.TextColor3=C.sub
            cLbl.Font=Enum.Font.Code; cLbl.TextSize=8
            cLbl.TextXAlignment=Enum.TextXAlignment.Left

            local chk=Instance.new("TextLabel",Row)
            chk.Text=farmTargets[pname] and "✓" or ""
            chk.Size=UDim2.new(0,30,1,0); chk.Position=UDim2.new(1,-36,0,0)
            chk.BackgroundTransparency=1; chk.TextColor3=C.orange
            chk.Font=Enum.Font.GothamBold; chk.TextSize=16

            Row.MouseButton1Click:Connect(function()
                if farmTargets[pname] then
                    farmTargets[pname]=nil
                    chk.Text=""; pLbl.TextColor3=C.text
                    rStroke.Color=C.border; Row.BackgroundColor3=C.card
                else
                    farmTargets[pname]=true
                    chk.Text="✓"; pLbl.TextColor3=C.orange
                    rStroke.Color=C.orange; Row.BackgroundColor3=Color3.fromRGB(35,20,0)
                end
                saveSettings()
                local sel=0; for _ in pairs(farmTargets) do sel=sel+1 end
                FSCount.Text="  "..sel.." selected"
            end)
        end
    end

    FLayout:ApplyLayout()
    FScroll.CanvasSize=UDim2.new(0,0,0,FLayout.AbsoluteContentSize.Y+8)
    local sel=0; for _ in pairs(farmTargets) do sel=sel+1 end
    FSCount.Text="  "..sel.." selected · "..count.." shown"
end

buildFarmPetList("")
FSearchBox:GetPropertyChangedSignal("Text"):Connect(function() buildFarmPetList(FSearchBox.Text) end)
FRefreshBtn.MouseButton1Click:Connect(function()
    refreshPetCampaignMap()
    buildFarmPetList(FSearchBox.Text)
end)


task.spawn(function()
    while true do
        if states.farmActive then
            -- update battle indicator
            local inBattle=isInBattle()
            if inBattle then
                FSBattle.Text="● In battle"; FSBattle.TextColor3=C.green
                task.wait(2)
            else
                FSBattle.Text="● Not in battle"; FSBattle.TextColor3=C.sub

                -- build ordered target list
                farmTargetList={}
                for n,_ in pairs(farmTargets) do table.insert(farmTargetList,n) end

                if #farmTargetList==0 then
                    FSStatus.Text="ON · No targets selected"
                    task.wait(2)
                else
                    -- pick next target (round-robin)
                    if farmIndex>#farmTargetList then farmIndex=1 end
                    local target=farmTargetList[farmIndex]
                    farmIndex=farmIndex+1

                    -- resolve pet name to campaign folder
                    local campFolder = petToCampaign[target]
                    if not campFolder or campFolder=="" then
                        FSStatus.Text="⚠ No campaign found for: "..target
                        task.wait(2); continue
                    end
                    FSStatus.Text="⚔ "..target.." ("..campFolder..")"
                    SLbl.Text="Farm: "..target

                    -- auto switch to Farm team
                    applyPresetTeam("Farm")
                    task.wait(0.2)

                    -- find correct model and fire RequestBattle
                    local battleModel = findCampaignModelForPet(target)
                    if battleModel then
                        FSStatus.Text="⚔ "..target.." ("..battleModel.Name..")"
                        SLbl.Text="Farm: "..target
                        if not states.farmNoTP then
                            pcall(function()
                                local root=getRoot()
                                if not root then return end
                                local pos=battleModel:GetModelCFrame().Position
                                if (root.Position-pos).Magnitude>30 then
                                    root.CFrame=CFrame.new(pos+Vector3.new(0,5,0))
                                    task.wait(0.5)
                                end
                            end)
                        end
                        pcall(function() RequestBattle:FireServer(battleModel) end)
                    else
                        FSStatus.Text="⚠ No model found for: "..target
                        task.wait(2)
                    end
                    task.wait(1)
                end
            end
        else
            FSBattle.Text="● Not in battle"; FSBattle.TextColor3=C.sub
            task.wait(0.5)
        end
    end
end)

-- update farm status dot periodically
task.spawn(function()
    while true do task.wait(1)
        local inBattle=isInBattle()
        if states.farmActive then
            FSBattle.Text= inBattle and "● In battle" or "● Not in battle"
            FSBattle.TextColor3= inBattle and C.green or C.sub
        end
        local cnt=0; for _,_ in pairs(farmTargets) do cnt=cnt+1 end
        if states.farmActive then
            FSStatus.Text="ON · "..cnt.." target(s)"
        end
    end
end)


